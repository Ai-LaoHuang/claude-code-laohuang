{
  "name": "claude-code-laohuang",
  "version": "0.1.0",
  "author": "AI老黄",
  "private": true,
  "type": "module",
  "bin": {
    "claude-code-laohuang": "./bin/claude-code-laohuang"
  },
  "scripts": {
    "claude-code-laohuang": "bash ./bin/claude-code-laohuang",
    "start": "bash ./bin/claude-code-laohuang",
    "start:gpt55": "bash ./scripts/start-gpt55-bridge.sh",
    "desktop:dev": "cd desktop && bun run tauri dev",
    "desktop:gpt55": "bash ./scripts/start-desktop-gpt55-bridge.sh",
    "desktop:build": "cd desktop && bun run build",
    "desktop:build:sidecars": "cd desktop && bun run build:sidecars",
    "desktop:check": "cd desktop && bun run lint",
    "quality:laohuang": "bun ./scripts/quality-laohuang.ts",
    "test:desktop-server": "bun test src/desktop-server/__tests__",
    "smoke:laohuang-runtime": "bun ./scripts/smoke-laohuang-runtime.ts",
    "smoke:tools": "bun --feature BUDDY --feature PROACTIVE --feature KAIROS_BRIEF --feature KAIROS_DREAM --feature ULTRAPLAN --feature BRIDGE_MODE ./scripts/smoke-tools.ts",
    "smoke:provider-proxy": "bun --feature BUDDY --feature PROACTIVE --feature KAIROS_BRIEF --feature KAIROS_DREAM --feature ULTRAPLAN --feature BRIDGE_MODE ./scripts/smoke-provider-proxy.ts"
  },
  "pkg": {
    "scripts": "src/**/*.ts",
    "assets": [
      "vendor/**/*",
      "src/**/*.tsx",
      "src/**/*.md",
      "src/**/*.txt",
      "stubs/**/*"
    ],
    "targets": [
      "node20-win-x64"
    ],
    "outputPath": "dist"
  },
  "devDependencies": {
    "bun-types": "^1.3.11",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "^0.0.44",
    "@anthropic-ai/sdk": "^0.80.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1020.0",
    "@commander-js/extra-typings": "^14.0.0",
    "@growthbook/growthbook": "^1.6.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api-logs": "^0.214.0",
    "@opentelemetry/core": "^2.6.1",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.214.0",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "ajv": "^8.18.0",
    "asciichart": "^1.5.25",
    "auto-bind": "^5.0.1",
    "axios": "^1.14.0",
    "bidi-js": "^1.0.3",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "cli-boxes": "^4.0.1",
    "code-excerpt": "^4.0.0",
    "diff": "^8.0.4",
    "emoji-regex": "^10.6.0",
    "env-paths": "^4.0.0",
    "execa": "^9.6.1",
    "figures": "^6.1.0",
    "fuse.js": "^7.1.0",
    "get-east-asian-width": "^1.5.0",
    "google-auth-library": "^10.6.2",
    "highlight.js": "^11.11.1",
    "https-proxy-agent": "^8.0.0",
    "ignore": "^7.0.5",
    "indent-string": "^5.0.0",
    "ink": "^6.8.0",
    "jsonc-parser": "^3.3.1",
    "lodash-es": "^4.17.23",
    "lru-cache": "^11.2.7",
    "marked": "^17.0.5",
    "p-map": "^7.0.4",
    "picomatch": "^4.0.4",
    "proper-lockfile": "^4.1.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-reconciler": "^0.33.0",
    "semver": "^7.7.4",
    "shell-quote": "^1.8.3",
    "signal-exit": "^4.1.0",
    "stack-utils": "^2.0.6",
    "strip-ansi": "^7.2.0",
    "supports-hyperlinks": "^4.4.0",
    "tree-kill": "^1.2.2",
    "type-fest": "^5.5.0",
    "undici": "^7.24.6",
    "usehooks-ts": "^3.1.1",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-types": "^3.17.5",
    "wrap-ansi": "^10.0.0",
    "ws": "^8.20.0",
    "xss": "^1.0.15",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
