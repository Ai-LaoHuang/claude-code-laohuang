        "./stubs/anthropic-provider-sdks.ts"
      ],
      "@azure/identity": [
        "./stubs/azure-identity.ts"
      ],
      "vscode-languageserver-protocol": [
        "./stubs/any-module.ts"
      ],
      "plist": [
        "./stubs/any-module.ts"
      ],
